{
  "name": "@evpanda/sdk",
  "version": "0.0.1",
  "description": "EVPanda SDK — passive OCPI/OCPP traffic capture for embedding in customer OCPI servers and OCPP CSMS.",
  "keywords": [
    "ocpi",
    "ocpp",
    "ev-charging",
    "cpo",
    "emsp",
    "observability",
    "telemetry",
    "sdk",
    "evpanda"
  ],
  "author": "EVPanda",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ev-panda/evpanda-node.git"
  },
  "bugs": {
    "url": "https://github.com/ev-panda/evpanda-node/issues"
  },
  "homepage": "https://github.com/ev-panda/evpanda-node#readme",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && vitest run test/e2e.test.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "express": "*",
    "ws": "*",
    "@mongodb-js/zstd": "*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "ws": {
      "optional": true
    },
    "@mongodb-js/zstd": {
      "optional": true
    }
  }
}
